# Required
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-dam-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional
GDRIVE_FOLDER_ID=                     # Google Drive folder ID for sync (Phase 2)
SIGNED_URL_EXPIRY_MINUTES=60          # Signed URL lifetime in minutes (default: 60)
